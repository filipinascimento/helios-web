{
  "name": "helios-web",
  "version": "0.10.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:https": "vite --host --mode https",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test tests/basic-example.spec.js tests/ui-boot-no-errors.spec.js tests/docs-basic-network-io.spec.js --project=chrome-ci --reporter=line",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:webgpu": "playwright test --headed --project=chromium-webgpu-headed",
    "test:e2e:weighted": "playwright test --headed tests/edge-transparency.spec.js",
    "test:e2e:rendering-options": "playwright test --headed --project=chromium tests/rendering-options.spec.js",
    "test:e2e:layout-calibration": "playwright test tests/layout-calibration.spec.js --project=chromium",
    "perf:history": "node scripts/run-performance-history.mjs",
    "perf:storage": "node scripts/run-storage-performance.mjs",
    "perf:profile:1m": "node scripts/profile-1m-webgpu.mjs",
    "calibration:generate": "node scripts/layout-calibration/generate-layout-calibration.mjs",
    "calibration:run": "node scripts/layout-calibration/run-layout-calibration.mjs",
    "calibration:fit": "node scripts/layout-calibration/fit-layout-model.mjs",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "d3-force-3d": "github:filipinascimento/d3-force-3d",
    "d3-scale-chromatic": "^3.1.0",
    "helios-network": "^0.10.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@webgpu/types": "^0.1.49",
    "pngjs": "^7.0.0",
    "vite": "^5.4.10"
  },
  "main": "./dist/helios-web.umd.cjs",
  "module": "./dist/helios-web.es.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./dist/helios-web.es.js",
      "require": "./dist/helios-web.umd.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "docs",
    "README.md"
  ],
  "description": "WebGPU/WebGL graph visualization renderer for Helios.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/filipinascimento/helios-web.git"
  },
  "license": "MIT"
}
